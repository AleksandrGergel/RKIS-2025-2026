<Window x:Class="TodoApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoApp.Desktop.ViewModels"
        Title="TodoApp Desktop" Height="720" Width="1120" MinHeight="600" MinWidth="920"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <SolidColorBrush x:Key="TextBrush" Color="#1D2939"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#667085"/>
        <SolidColorBrush x:Key="LineBrush" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="94"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderBrush" Value="#C7CED8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,5,0,13"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderBrush" Value="#C7CED8"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,5,0,13"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="BorderBrush" Value="#C7CED8"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <Grid>
                <Border Width="390" Padding="30" Background="White" BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Вход" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Откройте свой список задач" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,24"/>

                        <TextBlock Text="Логин" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Пароль" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <Button Content="Войти" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButton}" Margin="0,4,0,6"/>
                        <Button Content="Создать профиль" Command="{Binding RegisterCommand}" Margin="0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Width="430" Padding="30" Background="White" BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,34">
                    <StackPanel>
                        <TextBlock Text="Регистрация" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Создайте профиль для хранения задач" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,24"/>

                        <TextBlock Text="Логин" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Пароль" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Имя" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Фамилия" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Год рождения" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding BirthYear, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <Button Content="Создать" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButton}" Margin="0,4,0,6"/>
                        <Button Content="Назад ко входу" Command="{Binding BackCommand}" Margin="0"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TodoListViewModel}">
            <DockPanel Margin="24">
                <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Поиск по тексту задачи" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Statuses}" SelectedItem="{Binding StatusFilter}" ToolTip="Фильтр по статусу" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button Content="Сброс" Command="{Binding ClearFilterCommand}"/>
                            <Button Content="Обновить" Command="{Binding RefreshCommand}"/>
                            <Button Content="Добавить" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Редактировать" Command="{Binding EditCommand}"/>
                            <Button Content="Удалить" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid ItemsSource="{Binding FilteredTodos}" SelectedItem="{Binding SelectedTodo}" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" RowHeight="40"
                          Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Index" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150"/>
                        <DataGridTextColumn Header="LastUpdate" Binding="{Binding LastUpdate, StringFormat=yyyy-MM-dd HH:mm}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AddTaskViewModel}">
            <Border Width="560" Padding="30" Background="White" BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Новая задача" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,22"/>
                    <TextBlock Text="Текст" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="130" TextWrapping="Wrap"/>
                    <TextBlock Text="Статус" Style="{StaticResource FormLabel}"/>
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}"/>
                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CancelCommand}"/>
                        <Button Content="Добавить" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EditTaskViewModel}">
            <Border Width="560" Padding="30" Background="White" BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Редактирование задачи" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,22"/>
                    <TextBlock Text="Текст" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="130" TextWrapping="Wrap"/>
                    <TextBlock Text="Статус" Style="{StaticResource FormLabel}"/>
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}"/>
                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CancelCommand}"/>
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="TodoApp Desktop" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ProfileTitle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Выйти" Command="{Binding LogoutCommand}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentView}"/>
    </DockPanel>
</Window>
